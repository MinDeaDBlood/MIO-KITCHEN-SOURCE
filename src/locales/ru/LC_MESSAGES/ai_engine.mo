msgstr "ИИ ДВИГАТЕЛЬ"

msgid "OK"
msgstr "ОК"

msgid "No idea about:\n\t%s\nPlease Report It To us."
msgstr "Нет идеи о:\n\t%s\nПожалуйста, сообщите нам об этом."

msgid "Unknown"
msgstr "Неизвестно"
