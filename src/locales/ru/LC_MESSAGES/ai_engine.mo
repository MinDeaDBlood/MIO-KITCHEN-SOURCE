msgid "File not found: %s"
msgstr "Файл не найден: %s"

msgid "Error parsing JSON file: %s"
msgstr "Ошибка при разборе JSON файла: %s"

msgid "The provided string is empty."
msgstr "Переданная строка пуста."

msgid "No errors found in the string."
msgstr "Ошибок в строке не обнаружено."

msgid "A window is already active. Creating a new window is canceled."
msgstr "Окно уже активно. Создание нового окна отменено."

